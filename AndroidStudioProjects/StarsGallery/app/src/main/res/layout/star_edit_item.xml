<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#080810">

    <!-- ID caché — logique inchangée -->
    <TextView
        android:id="@+id/idss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="id"
        android:visibility="gone" />

    <!-- Séparateur décoratif doré au-dessus de l'image -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="#D4AF6A"
        android:alpha="0.5"
        android:layout_marginBottom="24dp" />

    <!-- Image de la star -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/img"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/star"
        android:scaleType="centerCrop"
        android:elevation="8dp"
        app:civ_border_width="2.5dp"
        app:civ_border_color="#D4AF6A" />

    <!-- Rating modifiable -->
    <RatingBar
        android:id="@+id/ratingBar"
        style="@style/Widget.AppCompat.RatingBar.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:isIndicator="false"
        android:progressTint="#D4AF6A"
        android:secondaryProgressTint="#2A2A3A"
        android:layout_marginTop="6dp" />

    <!-- Séparateur décoratif doré en bas -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="#D4AF6A"
        android:alpha="0.5"
        android:layout_marginTop="24dp" />

</LinearLayout>
